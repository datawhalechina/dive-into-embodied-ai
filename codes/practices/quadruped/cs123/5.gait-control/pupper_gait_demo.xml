    <material name="left_leg" rgba="0.38 0.58 0.78 1"/>
    <material name="right_leg" rgba="0.46 0.64 0.54 1"/>
    <material name="joint" rgba="0.70 0.74 0.78 1"/>
    <material name="foot" rgba="0.86 0.22 0.22 1"/>
