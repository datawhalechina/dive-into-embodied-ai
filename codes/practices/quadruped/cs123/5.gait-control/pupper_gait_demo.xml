          <geom name="FL_thigh_geom" type="capsule" fromto="0 0 0 0 0 -0.08" class="leg_left" mass="0.16"/>
          <body name="FL_calf" pos="0 0 -0.08">
            <joint name="FL_KFE" type="hinge" axis="0 1 0" range="-2.6 0.1"/>
            <geom name="FL_calf_geom" type="capsule" fromto="0 0 0 0 0 -0.11" class="leg_left" size="0.011" mass="0.06"/>
