              <geom name="RL_foot_geom" class="foot"/>
              <site name="RL_foot" size="0.010" material="foot"/>
            </body>
          </body>
        </body>
      </body>

      <body name="RR_hip" pos="-0.075 -0.0725 0">
        <joint name="RR_HAA" type="hinge" axis="1 0 0" range="-0.8 0.8"/>
