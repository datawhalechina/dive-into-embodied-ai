#!/bin/sh

MAX_SIZE=512000

# Files to skip (large but must stay diffable)
SKIP_FILES="package-lock.json yarn.lock pnpm-lock.yaml"

OVERSIZED=$(git diff --cached --name-only --diff-filter=ACM | while read f; do
  if [ -f "$f" ]; then
    skip=0
    for s in $SKIP_FILES; do
      if [ "$f" = "$s" ]; then
        skip=1
        break
      fi
    done
    if [ "$skip" = "1" ]; then
      continue
    fi
    size=$(wc -c < "$f" | tr -d ' ')
    if git check-attr filter -- "$f" | grep -q "lfs"; then
      continue
    fi
    if [ "$size" -gt "$MAX_SIZE" ]; then
      echo "  $f ($(( size / 1024 ))KB)"
    fi
  fi
done)

if [ -n "$OVERSIZED" ]; then
  echo "ERROR: The following files exceed 500KB and are not tracked by Git LFS:"
  echo "$OVERSIZED"
  echo ""
  echo "Options:"
  echo "  1. Compress the file(s)"
  echo "  2. Add the file type to .gitattributes for LFS tracking"
  echo "  3. Use 'git commit --no-verify' to bypass (not recommended)"
  exit 1
fi
